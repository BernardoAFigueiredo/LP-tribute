			function chipsHtml(){
			  const chips = document.getElementById('chips');
			  chips.innerHTML = '';
			  MUSICIANS.forEach(m => {
			    const btn = document.createElement('button');
			    btn.className = 'chip' + (m.id === currentMusician ? ' active' : '');
			    btn.textContent = m.label;
			    btn.onclick = () => { currentMusician = m.id; openSong = null; render(); };
			    chips.appendChild(btn);
			  });
			}

			function keyFor(musician, songNum){ return `links:${musician}:${songNum}`; }

			async function loadMusicianData(musician){
			  dataCache = {};
			  if(typeof window === 'undefined' || !window.storage || typeof window.storage.list !== 'function'){
			    return;
			  }
			  try{
			    const res = await window.storage.list(`links:${musician}:`, false);
			    if(res && res.keys){
			      for(const k of res.keys){
			        try{
			          const item = await window.storage.get(k, false);
			          if(item){
			            const num = k.split(':')[2];
			            dataCache[num] = JSON.parse(item.value);
			          }
			        }catch(e){}
			      }
			    }
			  }catch(e){}
			}

			function searchLinks(title){
			  const q = encodeURIComponent(title + ' cifra club');
			  const qv = encodeURIComponent(title + ' Linkin Park');
			  return {
			    cifra: `https://www.google.com/search?q=${q}`,
			    video: `https://www.youtube.com/results?search_query=${qv}`
			  };
			}

			function linkButtonHtml(song){
			  const isGuitar = GUITAR_TABS.includes(currentMusician);
			  const isStemTab = STEM_TABS.includes(currentMusician);
			  const isBackingTab = BACKING_TABS.includes(currentMusician);
			  const defaultStem = (DEFAULT_STEMS[currentMusician] || {})[song.n] || '';
			  const defaultGuitarVideo = (DEFAULT_GUITAR_VIDEO[currentMusician] || {})[song.n] || '';
			  const defaultVideoByTab = (DEFAULT_VIDEO_BY_TAB[currentMusician] || {})[song.n] || '';
			  const defaultCifraNotVocal = !NO_CIFRA_TABS.includes(currentMusician) ? (DEFAULT_CIFRA_NOT_VOCAL[song.n] || '') : '';
			  const showVideo = !NO_VIDEO_TABS.includes(currentMusician);
			  const saved = dataCache[song.n] || {cifra:'', video:'', stem:'', backing:''};
			  if(isStemTab && !saved.stem && defaultStem){ saved.stem = defaultStem; }
			  if(isBackingTab && !saved.backing && (DEFAULT_BACKING_TRACK[currentMusician] || {})[song.n]){ saved.backing = (DEFAULT_BACKING_TRACK[currentMusician] || {})[song.n]; }
			  if(showVideo && isGuitar && !saved.video && defaultGuitarVideo){ saved.video = defaultGuitarVideo; }
			  if(showVideo && !isGuitar && !saved.video && defaultVideoByTab){ saved.video = defaultVideoByTab; }
			  if(!saved.cifra && defaultCifraNotVocal){ saved.cifra = defaultCifraNotVocal; }
			  const videoLabel = isGuitar ? 'Tab' : 'Vídeo de referência';
			  const showCifra = !NO_CIFRA_TABS.includes(currentMusician);
			  const search = searchLinks(song.title);
			  const isOpen = openSong === song.n;
			  const hasAny = !!((showCifra && saved.cifra) || (showVideo && saved.video) || (isStemTab && saved.stem) || (isBackingTab && saved.backing));

			  const el = document.createElement('div');
			  el.className = 'linkbtn' + (isOpen ? ' open' : '') + (hasAny ? ' has-links' : '');
			  el.innerHTML = `
			    <div class="linkbtn-head">
			      <span class="linkbtn-num">${String(song.n).padStart(2,'0')}</span>
			      <div class="linkbtn-title">
			        <div class="linkbtn-name">${song.title}</div>
			        <div class="linkbtn-meta">${song.key} · ${song.bpm} bpm</div>
			      </div>
			      <div class="linkbtn-dots">
			        ${showCifra ? `<span class="${saved.cifra ? 'filled' : ''}"></span>` : ''}
			        ${showVideo ? `<span class="${saved.video ? 'filled' : ''}"></span>` : ''}
			        ${isStemTab ? `<span class="${saved.stem ? 'filled' : ''}"></span>` : ''}
			        ${isBackingTab ? `<span class="${saved.backing ? 'filled' : ''}"></span>` : ''}
			      </div>
			      <span class="chevron">▾</span>
			    </div>
			    <div class="linkbtn-body">
			      <div class="linkbtn-body-inner">
			        ${showCifra ? `
			        <span class="field-label">Cifra / Tab</span>
			        <div class="link-field">
			          <input type="url" placeholder="Cole o link da cifra" data-type="cifra" value="${saved.cifra || ''}">
			          <a class="go ${saved.cifra ? 'has-link' : ''}" ${saved.cifra ? `href="${saved.cifra}" target="_blank" rel="noopener"` : ''} data-type="cifra" title="Abrir">↗</a>
			        </div>` : ''}
			        ${showVideo ? `
			        <span class="field-label">${videoLabel}</span>
			        <div class="link-field">
			          <input type="url" placeholder="Cole o link do vídeo" data-type="video" value="${saved.video || ''}">
			          <a class="go ${saved.video ? 'has-link' : ''}" ${saved.video ? `href="${saved.video}" target="_blank" rel="noopener"` : ''} data-type="video" title="Abrir">↗</a>
			        </div>` : ''}
			        ${isStemTab ? `
			        <span class="field-label">Stem</span>
			        <div class="link-field">
			          <input type="url" placeholder="Cole o link do stem" data-type="stem" value="${saved.stem || ''}">
			          <a class="go ${saved.stem ? 'has-link' : ''}" ${saved.stem ? `href="${saved.stem}" target="_blank" rel="noopener"` : ''} data-type="stem" title="Abrir">↗</a>
			        </div>` : ''}
			        ${isBackingTab ? `
			        <span class="field-label">Backing Track</span>
			        <div class="link-field">
			          <input type="url" placeholder="Cole o link do backing track" data-type="backing" value="${saved.backing || ''}">
			          <a class="go ${saved.backing ? 'has-link' : ''}" ${saved.backing ? `href="${saved.backing}" target="_blank" rel="noopener"` : ''} data-type="backing" title="Abrir">↗</a>
			        </div>` : ''}
			        <div class="search-row">
			          ${showCifra ? `<a class="search-chip" href="${search.cifra}" target="_blank" rel="noopener">buscar cifra ↗</a>` : ''}
			          ${showVideo ? `<a class="search-chip" href="${search.video}" target="_blank" rel="noopener">buscar vídeo ↗</a>` : ''}
			        </div>
			        <div class="status"></div>
			      </div>
			    </div>
			  `;

			  const head = el.querySelector('.linkbtn-head');
			  head.addEventListener('click', () => {
			    openSong = isOpen ? null : song.n;
			    render();
			  });

			  const cifraInput = el.querySelector('input[data-type="cifra"]');
			  const videoInput = el.querySelector('input[data-type="video"]');
			  const stemInput = el.querySelector('input[data-type="stem"]');
			  const backingInput = el.querySelector('input[data-type="backing"]');
			  const cifraGo = el.querySelector('.go[data-type="cifra"]');
			  const videoGo = el.querySelector('.go[data-type="video"]');
			  const stemGo = el.querySelector('.go[data-type="stem"]');
			  const backingGo = el.querySelector('.go[data-type="backing"]');
			  const status = el.querySelector('.status');

			  function updateGo(input, goBtn){
			    if(!input || !goBtn) return;
			    if(input.value){ goBtn.href = input.value; goBtn.target = '_blank'; goBtn.rel = 'noopener'; goBtn.classList.add('has-link'); }
			    else { goBtn.removeAttribute('href'); goBtn.classList.remove('has-link'); }
			  }
			  updateGo(cifraInput, cifraGo);
			  updateGo(videoInput, videoGo);
			  updateGo(stemInput, stemGo);
			  updateGo(backingInput, backingGo);

			  [cifraInput, videoInput, stemInput, backingInput].forEach(inp => { if(inp) inp.addEventListener('click', e => e.stopPropagation()); });

			  let saveTimeout;
			  async function save(){
			    const value = {
			      cifra: cifraInput ? cifraInput.value.trim() : (saved.cifra || ''),
			      video: videoInput ? videoInput.value.trim() : (saved.video || ''),
			      stem: stemInput ? stemInput.value.trim() : (saved.stem || ''),
			      backing: backingInput ? backingInput.value.trim() : (saved.backing || '')
			    };
			    dataCache[song.n] = value;
			    updateGo(cifraInput, cifraGo);
			    updateGo(videoInput, videoGo);
			    updateGo(stemInput, stemGo);
			    updateGo(backingInput, backingGo);
			    const dots = el.querySelectorAll('.linkbtn-dots span');
			    let dotIdx = 0;
			    if(showCifra){ dots[dotIdx].classList.toggle('filled', !!value.cifra); dotIdx++; }
			    if(showVideo){ dots[dotIdx].classList.toggle('filled', !!value.video); dotIdx++; }
			    if(isStemTab && dots[dotIdx]){ dots[dotIdx].classList.toggle('filled', !!value.stem); dotIdx++; }
			    if(isBackingTab && dots[dotIdx]){ dots[dotIdx].classList.toggle('filled', !!value.backing); }
			    el.classList.toggle('has-links', !!((showCifra && value.cifra) || (showVideo && value.video) || value.stem || value.backing));
			    try{
			      const result = await window.storage.set(keyFor(currentMusician, song.n), JSON.stringify(value), false);
			      status.textContent = result ? 'salvo ✓' : 'erro ao salvar';
			      status.className = 'status' + (result ? ' saved' : '');
			      setTimeout(()=>{ status.textContent=''; status.className='status'; }, 1500);
			    }catch(e){
			      status.textContent = 'erro ao salvar';
			    }
			  }
			  function debounceSave(){
			    clearTimeout(saveTimeout);
			    saveTimeout = setTimeout(save, 500);
			  }
			  if(cifraInput) cifraInput.addEventListener('input', debounceSave);
			  if(videoInput) videoInput.addEventListener('input', debounceSave);
			  if(stemInput) stemInput.addEventListener('input', debounceSave);
			  if(backingInput) backingInput.addEventListener('input', debounceSave);

			  return el;
			}

			function drawSongList(){
			  const list = document.getElementById('songlist');
			  list.innerHTML = '';
			  SETLIST.forEach(atoGroup => {
			    const divider = document.createElement('div');
			    divider.className = 'ato-divider';
			    divider.innerHTML = `<span class="line"></span><span class="label"><b>${atoGroup.ato}º ATO</b> — ${atoGroup.atoName}</span><span class="line"></span>`;
			    list.appendChild(divider);
			    atoGroup.songs.forEach(song => {
			      list.appendChild(linkButtonHtml(song));
			    });
			  });
			}

			function render(){
			  chipsHtml();
			  dataCache = {};
			  drawSongList();
			  loadMusicianData(currentMusician).then(() => {
			    drawSongList();
			  }).catch(()=>{});
			}

			render();
		</script>
