			href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
			rel="stylesheet"
		/>
		<style>
			:root{
			  --bg: #0a0a0b;
			  --card: #18181a;
			  --card-hover: #1f1f22;
			  --line: #2b2b2e;
			  --red: #d21f2f;
			  --red-dim: #7a1620;
			  --white: #f0f0f0;
			  --grey: #8c8c90;
			  --grey-dim: #5a5a5e;
			}
			*{box-sizing:border-box;}
			html,body{margin:0;padding:0;}
			body{
			  background: var(--bg);
			  background-image:
			    radial-gradient(ellipse at top, rgba(210,31,47,0.10), transparent 50%),
			    radial-gradient(ellipse at bottom, rgba(210,31,47,0.05), transparent 55%);
			  color: var(--white);
			  font-family: 'IBM Plex Sans', sans-serif;
			  min-height: 100vh;
			  -webkit-font-smoothing: antialiased;
			}
			.wrap{ max-width: 460px; margin: 0 auto; padding: 40px 18px 60px; }

			/* PROFILE */
			.profile{ display:flex; flex-direction:column; align-items:center; text-align:center; margin-bottom: 28px; }
			.ring{
			  width: 92px; height: 92px; border-radius: 50%;
			  padding: 3px;
			  background: conic-gradient(from 180deg, var(--red), #3a0a0f, var(--red));
			  margin-bottom: 14px;
			}
			.avatar{
			  width:100%; height:100%; border-radius:50%;
			  background: var(--bg);
			  display:flex; align-items:center; justify-content:center;
			  position:relative; overflow:hidden;
			  border: 2px solid var(--bg);
			}
			.avatar img{ width: 108%; height: 108%; object-fit: cover; }

			.handle{ font-size: 12.5px; color: var(--red); letter-spacing:.5px; font-weight:600; margin-bottom: 4px; }
			h1{
			  font-family:'Bebas Neue', sans-serif;
			  font-size: 30px;
			  letter-spacing: .5px;
			  margin: 0 0 6px;
			  text-transform: uppercase;
			  line-height: 1;
			}
			.bio{ color: var(--grey); font-size: 12.5px; max-width: 320px; line-height:1.5; }

			/* INSTRUMENT CHIPS */
			.chips{
			  display:flex; gap:7px; flex-wrap:wrap; justify-content:center;
			  margin: 20px 0 26px;
			}
			.chip{
			  background: var(--card);
			  border: 1px solid var(--line);
			  color: var(--grey);
			  font-weight:600;
			  font-size: 11.5px;
			  letter-spacing:.3px;
			  text-transform: uppercase;
			  padding: 8px 13px;
			  border-radius: 999px;
			  cursor: pointer;
			  transition: all .15s ease;
			}
			.chip:hover{ color: var(--white); border-color: var(--grey-dim); }
			.chip.active{ background: var(--red); border-color: var(--red); color: #fff; }

			/* ATO DIVIDER */
			.ato-divider{
			  display:flex; align-items:center; gap:10px;
			  margin: 22px 0 12px;
			}
			.ato-divider:first-of-type{ margin-top: 0; }
			.ato-divider .line{ flex:1; height:1px; background: var(--line); }
			.ato-divider .label{
			  font-family:'Bebas Neue'; font-size:14px; letter-spacing:1.5px;
			  color: var(--grey); white-space:nowrap;
			}
			.ato-divider .label b{ color: var(--red); }

			/* LINK BUTTON (linktree style) */
			.linkbtn{
			  background: var(--card);
			  border: 1px solid var(--line);
			  border-radius: 14px;
			  margin-bottom: 10px;
			  overflow: hidden;
			  transition: border-color .15s ease, background .15s ease;
			}
			.linkbtn.has-links{ border-color: var(--red-dim); }
			.linkbtn-head{
			  display:flex; align-items:center; gap:12px;
			  padding: 13px 16px;
			  cursor: pointer;
			  user-select:none;
			}
			.linkbtn-head:hover{ background: var(--card-hover); }
			.linkbtn-num{
			  font-family:'IBM Plex Mono'; font-size:11px; color: var(--red);
			  background: rgba(210,31,47,0.12);
			  width: 24px; height:24px; border-radius:50%;
			  display:flex; align-items:center; justify-content:center;
			  flex-shrink:0;
			}
			.linkbtn-title{ flex:1; min-width:0; }
			.linkbtn-name{ font-weight:600; font-size: 14px; letter-spacing:.2px; }
			.linkbtn-meta{ font-family:'IBM Plex Mono'; font-size: 10.5px; color: var(--grey-dim); margin-top:1px; }
			.linkbtn-dots{ display:flex; gap:3px; flex-shrink:0; }
			.linkbtn-dots span{ width:5px; height:5px; border-radius:50%; background: var(--grey-dim); }
			.linkbtn-dots span.filled{ background: var(--red); }
			.chevron{ color: var(--grey-dim); font-size: 11px; transition: transform .2s ease; flex-shrink:0; }
			.linkbtn.open .chevron{ transform: rotate(180deg); }

			.linkbtn-body{
			  max-height: 0;
			  overflow: hidden;
			  transition: max-height .25s ease;
			}
			.linkbtn.open .linkbtn-body{ max-height: 260px; }
			.linkbtn-body-inner{ padding: 0 16px 16px; }

			.field-label{ font-size: 9.5px; text-transform:uppercase; letter-spacing:1px; color: var(--red); margin: 10px 0 4px; display:block; }
			.field-label:first-child{ margin-top:2px; }
			.link-field{ display:flex; gap:6px; }
			.link-field input{
			  flex:1; min-width:0;
			  background: var(--bg);
			  border: 1px solid var(--line);
			  color: var(--white);
			  font-size: 12.5px;
			  padding: 8px 10px;
			  border-radius: 8px;
			  font-family:'IBM Plex Sans';
			}
			.link-field input::placeholder{ color: var(--grey-dim); }
			.link-field input:focus{ outline:none; border-color: var(--red-dim); }
			.link-field .go{
			  background: var(--bg);
			  border: 1px solid var(--line);
			  color: var(--grey);
			  width: 34px; flex-shrink:0;
			  border-radius:8px;
			  cursor:pointer;
			  font-size:13px;
			  display:flex; align-items:center; justify-content:center;
			  text-decoration:none;
			}
			.link-field .go.has-link{ color: var(--red); border-color: var(--red-dim); }
			.link-field .go:hover{ background: var(--red); color:#fff; border-color:var(--red); }

			.search-row{ display:flex; gap:8px; margin-top:10px; }
			.search-chip{
			  font-size: 10px; color: var(--grey);
			  text-decoration:none;
			  border: 1px dashed var(--line);
			  padding: 4px 9px;
			  border-radius: 999px;
			  transition: all .15s;
			}
			.search-chip:hover{ color: var(--red); border-color: var(--red-dim); }

			.status{ font-size:10px; color: var(--grey-dim); margin-top:8px; min-height:12px; }
			.status.saved{ color: var(--red); }

			.fixed-link{
			  display:flex; align-items:center; gap:12px;
			  background: var(--card);
			  border: 1px solid #1DB95440;
			  border-radius: 14px;
			  padding: 13px 16px;
			  margin-bottom: 22px;
			  text-decoration:none;
			  color: var(--white);
			  transition: background .15s ease, border-color .15s ease;
			}
			.fixed-link:hover{ background: var(--card-hover); border-color: #1DB954; }
			.fixed-link .icon{
			  width: 34px; height:34px; border-radius:50%;
			  background: #1DB954;
			  display:flex; align-items:center; justify-content:center;
			  flex-shrink:0;
			}
			.fixed-link .icon svg{ width:18px; height:18px; }
			.fixed-link .text{ flex:1; min-width:0; }
			.fixed-link .text .t1{ font-weight:600; font-size:14px; }
			.fixed-link .text .t2{ font-size:11px; color: var(--grey); margin-top:1px; }
			.fixed-link .arrow{ color: var(--grey-dim); font-size:16px; flex-shrink:0; }

			footer{ margin-top: 34px; text-align:center; color: var(--grey-dim); font-size:11px; letter-spacing:.5px; }

			footer .made{ font-family:'Bebas Neue'; color:var(--grey); font-size:15px; letter-spacing:1.5px; margin-bottom:4px;}
		</style>
